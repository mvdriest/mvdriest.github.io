[{"data":1,"prerenderedAt":190},["ShallowReactive",2],{"project-data:bataviadigital":3},{"id":4,"title":5,"body":6,"description":178,"extension":179,"gridOrder":180,"meta":181,"navigation":183,"path":184,"projectAssetsDir":88,"seo":185,"stem":186,"tags":187,"__hash__":189},"projecten\u002Fprojecten\u002Fbataviadigital.md","Batavia Digital",{"type":7,"value":8,"toc":174},"minimark",[9,38,49,76,99,121,128,145],[10,11,14,23],"div",{"className":12},[13],"case-row",[10,15,18],{"className":16},[17],"case-row-title",[19,20,22],"h2",{"id":21},"intro","Intro",[10,24,27,33],{"className":25},[26],"case-row-body",[28,29,32],"p",{"className":30},[31],"case-text-lg","Batavia Digital is een marketing agency dat ik momenteel aan het opbouwen ben. Het doel van het merk is om bedrijven te helpen groeien met sterke branding, websites en digitale strategie.",[28,34,37],{"className":35},[36],"case-text-sm","Voor dit project ontwikkelde ik zowel de visuele identiteit als het ontwerp van de website.",[10,39,42],{"className":40},[41],"case-media",[43,44],"gradient-image-card",{"alt":45,"gradient-from":46,"gradient-to":47,"src":48},"Batavia Digital homepage","#E94F1B","#F39200","\u002Fimages\u002Fother\u002Fbatavia_home.jpg",[10,50,53,60],{"className":51},[13,52],"case-row--spaced",[10,54,56],{"className":55},[17],[19,57,59],{"id":58},"branding","Branding",[10,61,63,67,72],{"className":62},[26],[28,64,66],{"className":65},[31],"Voor Batavia Digital ontwierp ik de volledige visuele identiteit van het merk. De branding is krachtig en herkenbaar, met een duidelijke Nederlandse signatuur.",[28,68,71],{"className":69},[70],"case-text-md","Het logo bestaat uit een leeuw met een megafoon. Dit sluit aan bij de gedachte achter het merk: bedrijven helpen om online beter zichtbaar te worden. ",[28,73,75],{"className":74},[36],"De tagline “Laat je merk online bruuullen” versterkt dit idee.",[10,77,80,92,96],{"className":78},[41,79],"case-media-grid",[10,81,84],{"className":82},[83],"case-media-span-2",[85,86],"image-gallery",{":images":87,"base-dir":88,"gallery":89,"layout":90,":tight":91},"[\"\u002Fimages\u002Fother\u002Fbatavia_textlogo.jpg\"]","bataviadigital","gallery1","single","true",[85,93],{":images":94,"base-dir":88,"gallery":89,"layout":95},"[\"\u002Fimages\u002Fother\u002Fbatavia_social.jpg\"]","single-tall",[85,97],{":images":98,"base-dir":88,"gallery":89,"layout":95},"[\"\u002Fimages\u002Fother\u002Fbatavia_vlag.jpg\"]",[10,100,102,109],{"className":101},[13,52],[10,103,105],{"className":104},[17],[19,106,108],{"id":107},"website","Website",[10,110,112,113,117],{"className":111},[26]," ",[28,114,116],{"className":115},[31],"Naast de branding werk ik aan de ontwikkeling van de website van Batavia Digital. De site wordt ontworpen en gebouwd in Webflow.",[28,118,120],{"className":119},[36],"De website heeft als doel om potentiële klanten te informeren en tegelijkertijd de creatieve en energieke uitstraling van het merk te laten zien.",[10,122,124],{"className":123},[41],[43,125],{"alt":45,"gradient-from":46,"gradient-to":47,"src":48,":cycle-images":126,"duration":127},"[\"\u002Fimages\u002Fother\u002Fbatavia_home.jpg\", \"\u002Fimages\u002Fother\u002Fbatavia_stacked.jpg\", \"\u002Fimages\u002Fother\u002Fbatavia_team.jpg\"]","1.5",[10,129,131,138],{"className":130},[13,52],[10,132,134],{"className":133},[17],[19,135,137],{"id":136},"resultaat","Resultaat",[10,139,141],{"className":140},[26],[28,142,144],{"className":143},[31],"Met Batavia Digital ontwikkel ik een merk dat branding, webdesign en digitale strategie combineert in één duidelijke identiteit.",[10,146,149,158,166],{"className":147},[148],"case-kpis",[10,150,112,153],{"className":151},[152],"case-kpi",[28,154,157],{"className":155},[31,156],"pb-0","Ontwikkeling van de visuele identiteit",[10,159,112,162],{"className":160},[152,161],"case-kpi--orange",[28,163,165],{"className":164},[31],"Ontwerp van de website",[10,167,112,170],{"className":168},[152,169],"case-kpi--blue",[28,171,173],{"classNam