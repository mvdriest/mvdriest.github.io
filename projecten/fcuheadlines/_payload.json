02F\u002Fwww.instagram.com\u002Ftv\u002FCZEJjVnBxC0\u002F\"},\n{\"title\":\"FCUHeadlines 2\",\"url\":\"https:\u002F\u002Fwww.instagram.com\u002Fp\u002FCZFO2NuK5GE\u002F\"},\n{\"title\":\"FCUHeadlines 3\",\"url\":\"https:\u002F\u002Fwww.instagram.com\u002Fp\u002FCSjVtEgKof8\u002F\"}\n]",[10,99,101],{"className":100},[92],[94,102],{":columns":96,":videos":103},"[\n{\"title\":\"FCU_Fans 1\",\"url\":\"https:\u002F\u002Fwww.instagram.com\u002Fp\u002FCh_xN8fKUGe\u002F\"},\n{\"title\":\"FCU_Fans 2\",\"url\":\"https:\u002F\u002Fwww.instagram.com\u002Fp\u002FCdvJC_yK6F9\u002F\"},\n{\"title\":\"FCU_Fans 3\",\"url\":\"https:\u002F\u002Fwww.instagram.com\u002Fp\u002FCfbk4HOqSOw\u002F\"}\n]",[10,105,107,114],{"className":106},[13,47],[10,108,110],{"className":109},[17],[19,111,113],{"id":112},"video-storytelling","Video & Storytelling",[10,115,117,121],{"className":116},[26],[28,118,120],{"className":119},[31],"Voor het TikTok-account Orangefootbal richtte ik me vooral op videomontage en storytelling.",[28,122,124],{"className":123},[65],"Door het gebruik van muziek, ritme en sfeerbeelden probeerde ik de emotie rondom voetbalmomenten vast te leggen. Eén van de video’s, gericht op de beleving rondom AFC Ajax, behaalde meer dan 250.000 weergaven en kreeg veel positieve reacties van kijkers.",[10,126,128],{"className":127},[92],[129,130],"shorts-spotlight",{":items":131},"[\n{\"title\":\"AFC Ajax beleving\",\"views\":\"250K+ views\",\"src\":\"\u002Fimages\u002Fother\u002Fajax_short.mp4\",\"href\":\"https:\u002F\u002Fwww.tiktok.com\u002F@orangefootbal\u002Fvideo\u002F7470610747098303767?is_from_webapp=1&sender_device=pc\"}\n]",[10,133,135,142],{"className":134},[13,47],[10,136,138],{"className":137},[17],[19,139,141],{"id":140},"resultaat","Resultaat",[10,143,145,149],{"className":144},[26],[28,146,148],{"className":147},[31],"De accounts groeiden uit tot actieve communities van supporters die regelmatig interactie hadden met de content.",[28,150,152],{"className":151},[65],"Dit project laat mijn ervaring zien met het maken van visuele content en videomontage voor social media, waarbij snelheid, herkenbaarheid en betrokkenheid van het publiek centraal staan.",[10,154,157,167,175],{"className":155},[156],"case-kpis",[10,158,161,162],{"className":159},[160],"case-kpi"," ",[28,163,166],{"className":164},[31,165],"pb-0","250.000+ views op een TikTok video",[10,168,161,171],{"className":169},[160,170],"case-kpi--orange",[28,172,174],{"className":173},[31],"2.456 volgers op FCU_Fans",[10,176,161,179],{"className":177},[160,178],"case-kpi--blue",[28,180,182],{"className":181},[31,165],"Visuele stijl voor matchday en content",{"title":184,"searchDepth":185,"depth":185,"links":186},"",2,[],"Ik geloof in een wereld waar sterke websites, cinematische video, krachtige fotografie en consistente branding je merk laten opvallen zoals het verdient.","md",null,{"link":191},"https:\u002F\u002Fwww.autoatlas.nl",true,"\u002Fprojecten\u002Ffcuheadlines","fcuheadlines",{"title":5,"description":187},"projecten\u002Ffcuheadlines",[198,199],"VIDEO EDITING","VISUAL DESIGN","GdcDLkSomfOboKOoRWBsh0vDvTLY1Ig8mfyfNZ6SRok",1774637484811]